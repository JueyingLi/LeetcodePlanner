# --- Backend ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Supabase Postgres connection (use the Session/Transaction Pooler URI).
# Note the +asyncpg driver suffix.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@<host>:5432/postgres

# Supabase auth — from Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=

# JSON array of allowed CORS origins (dev default already includes localhost:5173)
# CORS_ORIGINS=["http://localhost:5173","https://your-app.onrender.com"]

# Optional LeetCode discussion scraper. Use your own browser session cookie.
# Never commit real cookie values.
LEETCODE_COOKIE=
LEETCODE_CSRF=

# --- Frontend (build-time, Vite) ---
# Put these in frontend/.env.local for local dev:
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon public key>
